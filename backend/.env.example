# 复制为 backend/.env（勿提交含真实 Key 的文件）

# —— 推荐：OpenRouter（OpenAI 兼容，统一路由多模型）——
# 文档：https://openrouter.ai/docs
OPENROUTER_API_KEY=
# 可选，默认 https://openrouter.ai/api/v1
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# 可选；模型 slug，如 openai/gpt-4o-mini、google/gemini-2.0-flash-001 等（须支持 vision）
# OPENROUTER_MODEL=openai/gpt-4o-mini
# OpenRouter 可选：应用展示名与来源站点（排行榜/归因）
# OPENROUTER_APP_TITLE=Tomato Note Graph
# OPENROUTER_HTTP_REFERER=http://localhost:5173

# —— 或：OpenAI 官方 / 其他兼容接口 ——
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# 无 API Key 时联调 UI：返回固定假数据（若已配置 Key，此项会被忽略）
# TOMATO_USE_STUB=1
# 即使已配置 Key 也强制假数据（一般勿开）
# TOMATO_FORCE_STUB=1

# —— 个人知识库（本机 Markdown 目录）——
# 若设置 TOMATO_KB_DIR，则始终使用该路径（优先级最高，且 Web 端不可覆盖）
# 未设置时：可用 Web 页「个人知识库」或 PUT /api/kb/root 写入 {TOMATO_DATA_DIR}/kb_root.json
# 默认目录仍为 {TOMATO_DATA_DIR}/knowledge_base（可与代码仓库完全分离）
# TOMATO_KB_DIR=/path/to/your/vault

# 定期整理线程：启动后首次延迟（秒）、周期（秒）；设为 0 关闭定期（仍可 POST /api/kb/maintain）
# TOMATO_KB_MAINTENANCE=1
# TOMATO_KB_MAINTENANCE_FIRST_DELAY_SEC=120
# TOMATO_KB_MAINTENANCE_INTERVAL_SEC=86400

# 每条笔记保存后是否再跑一轮整理（会调 LLM，有费用；频繁上传可关）
# TOMATO_KB_MAINTENANCE_ON_SAVE=1

# 维护时是否用 LLM 写「知识库索引.md」（无 Key 时自动退化为文件列表索引）
# TOMATO_KB_MAINTENANCE_LLM=1

# 整理索引专用模型（默认与 OPENROUTER_MODEL / OPENAI_MODEL 相同）
# TOMATO_KB_MAINTENANCE_MODEL=gpt-4o-mini

# 由知识点标题生成的笔记文件名最大长度（字符）
# TOMATO_KB_NOTE_NAME_MAX_LEN=72
